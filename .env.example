# DeepSeek AI — get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio WhatsApp — get these from https://console.twilio.com -> Account Info
# For dev: use the sandbox number whatsapp:+14155238886
# For prod: use your provisioned Twilio WhatsApp number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Database — SQLite for local dev (no config needed), PostgreSQL for prod
# PostgreSQL format: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./krucx_leads.db

# Optional: Meta Cloud API webhook verification token (only needed if switching from Twilio)
# META_VERIFY_TOKEN=your_verify_token_here
